<%- include('partials/header') %>

<!-- Page Header -->
<div class="bg-maroon text-white py-10 px-4">
  <div class="max-w-7xl mx-auto">
    <h1 class="font-playfair text-3xl md:text-4xl font-bold"><%= pageTitle %></h1>
    <div class="flex items-center gap-2 text-white/60 text-sm mt-2">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <i class="fas fa-chevron-right text-xs"></i>
      <span class="text-gold">Shop</span>
    </div>
  </div>
</div>

<section class="py-8 md:py-12 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Search + Filter Bar -->
    <form method="GET" action="/products" class="bg-white rounded-2xl shadow-sm p-4 md:p-6 mb-8 border border-gray-100">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <!-- Search -->
        <div class="lg:col-span-2 relative">
          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
          <input type="text" name="search" value="<%= query.search || '' %>"
                 placeholder="Search poshak, mukut, colors..."
                 class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
        </div>

        <!-- Category -->
        <select name="category" class="border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-maroon transition-all text-gray-600">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.slug %>" <%= query.category === cat.slug ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>

        <!-- Sort -->
        <select name="sort" class="border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-maroon transition-all text-gray-600">
          <option value="newest" <%= query.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="price-asc" <%= query.sort === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
          <option value="price-desc" <%= query.sort === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
          <option value="popular" <%= query.sort === 'popular' ? 'selected' : '' %>>Most Popular</option>
          <option value="name-asc" <%= query.sort === 'name-asc' ? 'selected' : '' %>>Name: A-Z</option>
        </select>

        <!-- Search Button -->
        <button type="submit" class="bg-maroon hover:bg-maroon-light text-white py-2.5 px-6 rounded-xl font-raleway font-medium text-sm transition-all duration-200 flex items-center justify-center gap-2">
          <i class="fas fa-filter"></i> Filter
        </button>
      </div>

      <!-- Price Range -->
      <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100">
        <span class="text-sm text-gray-500 font-raleway whitespace-nowrap">Price Range:</span>
        <input type="number" name="minPrice" value="<%= query.minPrice || '' %>" placeholder="Min ₹"
               class="w-28 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-maroon" />
        <span class="text-gray-400">—</span>
        <input type="number" name="maxPrice" value="<%= query.maxPrice || '' %>" placeholder="Max ₹"
               class="w-28 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-maroon" />
        <% if (query.search || query.category || query.sort || query.minPrice || query.maxPrice) { %>
          <a href="/products" class="text-sm text-maroon hover:underline ml-2">Clear All</a>
        <% } %>
      </div>
    </form>

    <!-- Result Count -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-500 text-sm">
        Showing <span class="font-semibold text-gray-800"><%= products.length %></span> of <span class="font-semibold text-gray-800"><%= total %></span> products
      </p>
      <% if (query.category) { %>
        <span class="bg-maroon-pale text-maroon text-xs px-3 py-1 rounded-full font-medium flex items-center gap-1.5">
          <i class="fas fa-tag text-xs"></i>
          <%= categories.find(c => c.slug === query.category)?.name || query.category %>
        </span>
      <% } %>
    </div>

    <!-- Products Grid -->
    <% if (products.length === 0) { %>
      <div class="text-center py-20">
        <i class="fas fa-box-open text-5xl text-gray-200 mb-4 block"></i>
        <h3 class="font-playfair text-2xl text-gray-400 mb-2">No Products Found</h3>
        <p class="text-gray-400 text-sm mb-6">Try adjusting your search or filter criteria.</p>
        <a href="/products" class="inline-flex items-center gap-2 bg-maroon text-white px-6 py-3 rounded-full text-sm font-medium hover:bg-maroon-light transition-colors">
          <i class="fas fa-arrow-left"></i> View All Products
        </a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        <% products.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    <% } %>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2 mt-12">
        <% if (currentPage > 1) { %>
          <a href="?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>"
             class="w-10 h-10 flex items-center justify-center border border-gray-200 rounded-xl text-gray-500 hover:border-maroon hover:text-maroon transition-all text-sm">
            <i class="fas fa-chevron-left"></i>
          </a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?<%= new URLSearchParams({...query, page: i}).toString() %>"
             class="w-10 h-10 flex items-center justify-center border rounded-xl text-sm font-medium transition-all
                    <%= i === currentPage ? 'bg-maroon border-maroon text-white' : 'border-gray-200 text-gray-600 hover:border-maroon hover:text-maroon' %>">
            <%= i %>
          </a>
        <% } %>
        <% if (currentPage < totalPages) { %>
          <a href="?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>"
             class="w-10 h-10 flex items-center justify-center border border-gray-200 rounded-xl text-gray-500 hover:border-maroon hover:text-maroon transition-all text-sm">
            <i class="fas fa-chevron-right"></i>
          </a>
        <% } %>
      </div>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
