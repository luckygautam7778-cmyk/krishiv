<%- include('partials/header') %>

<!-- Page Header -->
<div class="bg-maroon text-white py-10 px-4">
  <div class="max-w-7xl mx-auto">
    <h1 class="font-playfair text-3xl md:text-4xl font-bold">Shopping Cart</h1>
    <div class="flex items-center gap-2 text-white/60 text-sm mt-2">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <i class="fas fa-chevron-right text-xs"></i>
      <span class="text-gold">Cart</span>
    </div>
  </div>
</div>

<section class="py-10 md:py-14 bg-cream min-h-[60vh]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <% if (!cart || cart.length === 0) { %>
      <!-- Empty Cart -->
      <div class="text-center py-20">
        <div class="w-24 h-24 bg-maroon-pale rounded-full flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-shopping-bag text-maroon text-4xl"></i>
        </div>
        <h2 class="font-playfair text-3xl font-bold text-gray-700 mb-3">Your Cart is Empty</h2>
        <p class="text-gray-400 mb-8">Looks like you haven't added any poshak yet!</p>
        <a href="/products" class="inline-flex items-center gap-2 bg-maroon hover:bg-maroon-light text-white px-8 py-4 rounded-full font-raleway font-semibold transition-all hover:shadow-lg">
          <i class="fas fa-shopping-bag"></i> Start Shopping
        </a>
      </div>

    <% } else { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Cart Items -->
        <div class="lg:col-span-2 space-y-4" id="cartItems">
          <% cart.forEach(item => { %>
            <div class="cart-item bg-white rounded-2xl p-4 md:p-5 shadow-sm flex items-center gap-4 border border-gray-100" data-product-id="<%= item.productId %>">
              <!-- Image -->
              <div class="w-20 h-20 md:w-24 md:h-24 flex-shrink-0 rounded-xl overflow-hidden bg-gray-50 border border-gray-100">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-gray-200">
                    <i class="fas fa-image text-2xl"></i>
                  </div>
                <% } %>
              </div>

              <!-- Info -->
              <div class="flex-grow min-w-0">
                <h3 class="font-playfair text-base md:text-lg font-semibold text-gray-800 leading-tight line-clamp-2"><%= item.name %></h3>
                <p class="text-maroon font-bold text-lg mt-1">₹<%= item.price.toFixed(0) %></p>
              </div>

              <!-- Quantity Controls -->
              <div class="flex flex-col items-end gap-3 flex-shrink-0">
                <button onclick="removeCartItem('<%= item.productId %>')" class="text-gray-300 hover:text-red-500 transition-colors text-sm">
                  <i class="fas fa-trash"></i>
                </button>
                <div class="flex items-center border border-gray-200 rounded-xl overflow-hidden">
                  <button onclick="updateQty('<%= item.productId %>', -1)" class="w-8 h-8 text-gray-500 hover:bg-gray-50 flex items-center justify-center font-bold transition-colors">-</button>
                  <span class="item-qty w-8 text-center text-sm font-semibold text-gray-700"><%= item.quantity %></span>
                  <button onclick="updateQty('<%= item.productId %>', 1)" class="w-8 h-8 text-gray-500 hover:bg-gray-50 flex items-center justify-center font-bold transition-colors">+</button>
                </div>
                <p class="item-total text-sm font-semibold text-gray-600">₹<%= (item.price * item.quantity).toFixed(0) %></p>
              </div>
            </div>
          <% }) %>

          <!-- Continue Shopping -->
          <div class="flex items-center justify-between pt-2">
            <a href="/products" class="flex items-center gap-2 text-maroon hover:text-maroon-light text-sm font-medium transition-colors">
              <i class="fas fa-arrow-left"></i> Continue Shopping
            </a>
            <button onclick="clearCart()" class="text-sm text-gray-400 hover:text-red-500 transition-colors">
              <i class="fas fa-trash-alt mr-1"></i> Clear Cart
            </button>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
            <h2 class="font-playfair text-xl font-bold text-gray-800 mb-5 pb-4 border-b border-gray-100">Order Summary</h2>

            <div class="space-y-3 text-sm">
              <div class="flex justify-between text-gray-600">
                <span>Subtotal (<%= cartCount %> items)</span>
                <span id="summarySubtotal" class="font-semibold text-gray-800">₹<%= total.toFixed(0) %></span>
              </div>
              <div class="flex justify-between text-gray-600">
                <span>Shipping</span>
                <span id="summaryShipping" class="font-semibold text-gray-800">
                  <%= shipping === 0 ? '<span class="text-green-600">FREE</span>' : '₹' + shipping %>
                </span>
              </div>
              <% if (shipping === 0 && total > 0) { %>
                <p class="text-green-600 text-xs bg-green-50 px-3 py-2 rounded-lg">🎉 You've unlocked free shipping!</p>
              <% } else if (shipping > 0) { %>
                <p class="text-gray-400 text-xs">Add ₹<%= ((settings?.freeShippingAbove || 999) - total).toFixed(0) %> more for free shipping</p>
              <% } %>
              <div class="border-t border-gray-100 pt-3">
                <div class="flex justify-between font-bold text-lg">
                  <span class="text-gray-800">Total</span>
                  <span id="summaryTotal" class="text-maroon font-playfair">₹<%= grandTotal.toFixed(0) %></span>
                </div>
                <p class="text-gray-400 text-xs mt-1">Inclusive of all taxes</p>
              </div>
            </div>

            <div class="mt-4 bg-gold-pale border border-gold/30 rounded-xl p-3 flex items-center gap-2 text-sm">
              <i class="fas fa-money-bill-wave text-gold"></i>
              <span class="text-gray-600 font-medium">Cash on Delivery Available</span>
            </div>

            <a href="/checkout" class="mt-5 w-full flex items-center justify-center gap-2 bg-maroon hover:bg-maroon-light text-white font-raleway font-semibold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-lg text-base">
              Proceed to Checkout <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>

<script>
function updateQty(productId, delta) {
  const item = document.querySelector(`.cart-item[data-product-id="${productId}"]`);
  const qtyEl = item.querySelector('.item-qty');
  const currentQty = parseInt(qtyEl.textContent);
  const newQty = currentQty + delta;
  if (newQty < 1) return removeCartItem(productId);

    fetch('/cart/update', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-csrf-token': window.csrfToken || ''
    },
    body: JSON.stringify({ productId, quantity: newQty })
  }).then(r => r.json()).then(data => {
    if (data.success) window.location.reload();
  });
}

function removeCartItem(productId) {
  if (!confirm('Remove this item from cart?')) return;
  fetch('/cart/remove', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-csrf-token': window.csrfToken || ''
    },
    body: JSON.stringify({ productId })
  }).then(r => r.json()).then(data => {
    if (data.success) window.location.reload();
  });
}

function clearCart() {
  if (!confirm('Clear all items from cart?')) return;
  fetch('/cart/clear', {
    method: 'POST',
    headers: { 'x-csrf-token': window.csrfToken || '' }
  }).then(() => window.location.reload());
}
</script>
