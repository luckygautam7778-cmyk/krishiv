<%- include('partials/header') %>

<!-- ═══════════════════════════════════════════════
     HERO BANNER SLIDER
═══════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-maroon-dark" id="hero">
  <% if (banners && banners.length > 0) { %>
    <div class="hero-slider relative" id="heroSlider">
      <% banners.forEach((banner, i) => { %>
        <div class="hero-slide <%= i === 0 ? 'active' : '' %> absolute inset-0 transition-opacity duration-700"
             style="background-image: url('<%= banner.image %>'); background-size: cover; background-position: center;">
          <div class="absolute inset-0 bg-gradient-to-r from-maroon-dark/90 via-maroon/60 to-transparent"></div>
          <div class="relative z-10 h-full flex items-center max-w-7xl mx-auto px-6 lg:px-12">
            <div class="max-w-xl text-white py-24 md:py-32">
              <p class="text-gold uppercase tracking-[0.4em] text-sm font-medium mb-4 animate-fade-in">✦ Krishiv Poshak Collection ✦</p>
              <h1 class="font-playfair text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4"><%= banner.title %></h1>
              <% if (banner.subtitle) { %>
                <p class="text-white/80 text-lg md:text-xl mb-8 font-raleway"><%= banner.subtitle %></p>
              <% } %>
              <a href="<%= banner.link || '/products' %>"
                 class="inline-flex items-center gap-3 bg-gold hover:bg-gold-dark text-white font-raleway font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:shadow-xl hover:shadow-gold/30 hover:-translate-y-0.5 text-sm uppercase tracking-wider">
                <%= banner.buttonText || 'Shop Now' %>
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>

      <!-- Slider Controls -->
      <% if (banners.length > 1) { %>
        <button onclick="prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white w-12 h-12 rounded-full flex items-center justify-center transition-all">
          <i class="fas fa-chevron-left"></i>
        </button>
        <button onclick="nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white w-12 h-12 rounded-full flex items-center justify-center transition-all">
          <i class="fas fa-chevron-right"></i>
        </button>
        <!-- Dots -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-20">
          <% banners.forEach((_, i) => { %>
            <button onclick="goToSlide(<%= i %>)" class="slide-dot w-3 h-3 rounded-full bg-white/40 hover:bg-gold transition-all duration-300 <%= i === 0 ? 'bg-gold w-8' : '' %>"></button>
          <% }) %>
        </div>
      <% } %>
    </div>
    <div class="h-[80vh] min-h-[500px] max-h-[700px]"></div>

  <% } else { %>
    <!-- Default Hero (no banners) -->
    <div class="relative h-[80vh] min-h-[500px] max-h-[700px] overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #5C0F28 0%, #7B1536 50%, #9B2048 100%);">
        <!-- Decorative pattern -->
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"60\" height=\"60\"><circle cx=\"30\" cy=\"30\" r=\"20\" fill=\"none\" stroke=\"%23C9A84C\" stroke-width=\"1\"/></svg>'); background-size: 60px 60px;"></div>
      </div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-6">
        <div class="max-w-3xl text-white">
          <p class="text-gold uppercase tracking-[0.5em] text-sm font-medium mb-6">✦ श्री राधे कृष्ण ✦</p>
          <h1 class="font-playfair text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
            Krishiv <span class="text-gold">Poshak</span><br/>Collection
          </h1>
          <p class="text-white/80 text-lg md:text-xl mb-10 font-raleway max-w-2xl mx-auto">
            Handcrafted traditional poshak for Ladoo Gopal & deity idols. Adorned with love, devotion, and finest embellishments.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/products" class="inline-flex items-center gap-3 bg-gold hover:bg-gold-dark text-white font-raleway font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:shadow-xl hover:shadow-gold/30 hover:-translate-y-0.5 text-sm uppercase tracking-wider">
                Shop Collection <i class="fas fa-arrow-right"></i>

            </a>
            <a href="/contact" class="inline-flex items-center gap-3 border-2 border-white/40 hover:border-gold text-white hover:text-gold px-8 py-4 rounded-full transition-all duration-300 text-sm uppercase tracking-wider">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</section>

<!-- ═══════════════════════════════════════════════
     USP STRIP
═══════════════════════════════════════════════ -->
<section class="bg-gold py-4">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-white text-sm font-raleway font-medium">
      <div class="flex items-center justify-center gap-2">
        <i class="fas fa-truck"></i>
        <span>Free Shipping ₹999+</span>
      </div>
      <div class="flex items-center justify-center gap-2">
        <i class="fas fa-hand-holding-heart"></i>
        <span>Handcrafted with Devotion</span>
      </div>
      <div class="flex items-center justify-center gap-2">
        <i class="fas fa-money-bill-wave"></i>
        <span>Cash on Delivery</span>
      </div>
      <div class="flex items-center justify-center gap-2">
        <i class="fab fa-whatsapp"></i>
        <span>WhatsApp Support</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     CATEGORIES
═══════════════════════════════════════════════ -->
<% if (categories && categories.length > 0) { %>
<section class="py-16 md:py-20 bg-cream-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-gold uppercase tracking-widest text-xs font-medium mb-2">Browse By</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-bold text-gray-800">Our Collections</h2>
      <div class="mt-3 flex items-center justify-center gap-2">
        <div class="h-px w-16 bg-gold"></div>
        <i class="fas fa-om text-gold text-sm"></i>
        <div class="h-px w-16 bg-gold"></div>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      <% categories.forEach(cat => { %>
        <a href="/products?category=<%= cat.slug %>"
           class="group relative overflow-hidden rounded-2xl aspect-square shadow-md hover:shadow-xl transition-all duration-400 hover:-translate-y-1">
          <% if (cat.image) { %>
            <img src="<%= cat.image %>" alt="<%= cat.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
          <% } else { %>
            <div class="w-full h-full bg-gradient-to-br from-maroon to-maroon-light flex items-center justify-center">
              <i class="fas fa-star text-gold text-4xl opacity-50"></i>
            </div>
          <% } %>
          <div class="absolute inset-0 bg-gradient-to-t from-maroon-dark/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
            <h3 class="font-playfair text-lg font-semibold"><%= cat.name %></h3>
            <p class="text-gold text-xs mt-0.5 group-hover:underline transition-all">Shop Now →</p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ═══════════════════════════════════════════════
