    <div class="text-center mt-10">
      <a href="/products" class="inline-flex items-center gap-3 border-2 border-maroon text-maroon hover:bg-maroon hover:text-white px-8 py-3 rounded-full font-raleway font-semibold transition-all duration-300 text-sm uppercase tracking-wider">
        View All Products <i class="fas fa-arrow-right"></i>
