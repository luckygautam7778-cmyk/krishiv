      <p class="text-gold uppercase tracking-widest text-xs font-medium mb-2">Handpicked</p>
      <h2 class="font-playfair text-3xl md:text-4xl font-bold text-gray-800">Featured Poshak</h2>
      <div class="mt-3 flex items-center justify-center gap-2">
        <div class="h-px w-16 bg-gold"></div>
        <i class="fas fa-om text-gold text-sm"></i>
        <div class="h-px w-16 bg-gold"></div>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      <% featuredProducts.forEach(product => { %>
