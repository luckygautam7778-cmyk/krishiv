<script>
// Hero Slider
let currentSlide = 0;
const slides = document.querySelectorAll('.hero-slide');
const dots = document.querySelectorAll('.slide-dot');

function showSlide(n) {
  if (!slides.length) return;
  slides.forEach(s => { s.classList.remove('active'); s.style.opacity = '0'; s.style.zIndex = '0'; });
  dots.forEach((d, i) => { d.classList.remove('bg-gold', 'w-8'); d.classList.add('bg-white/40'); });
  currentSlide = (n + slides.length) % slides.length;
  slides[currentSlide].style.opacity = '1';
  slides[currentSlide].style.zIndex = '1';
  if (dots[currentSlide]) { dots[currentSlide].classList.add('bg-gold', 'w-8'); dots[currentSlide].classList.remove('bg-white/40'); }
}

function nextSlide() { showSlide(currentSlide + 1); }
function prevSlide() { showSlide(currentSlide - 1); }
function goToSlide(n) { showSlide(n); }

if (slides.length > 1) {
  showSlide(0);
  setInterval(nextSlide, 5000);
}
</script>
