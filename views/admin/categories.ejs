<%- include('../partials/admin-header') %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Add Category Form -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="font-playfair text-lg font-bold text-gray-800 mb-5">Add New Category</h2>
    <form action="/admin/categories/add" method="POST" enctype="multipart/form-data" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Category Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" required placeholder="e.g., Poshak Set, Mukut"
               class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
        <textarea name="description" rows="2" placeholder="Short description..."
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all resize-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Category Image</label>
        <input type="file" name="image" accept="image/*"
               class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Sort Order</label>
        <input type="number" name="sortOrder" value="0" min="0"
               class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
      </div>
      <button type="submit" class="w-full bg-maroon hover:bg-maroon-light text-white font-semibold py-3 rounded-xl transition-all hover:shadow-md flex items-center justify-center gap-2 text-sm">
        <i class="fas fa-plus"></i> Add Category
      </button>
    </form>
  </div>

  <!-- Categories List -->
  <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="font-playfair text-lg font-bold text-gray-800">All Categories (<%= categories.length %>)</h2>
    </div>

    <% if (categories.length === 0) { %>
      <div class="text-center py-12 text-gray-300">
        <i class="fas fa-tags text-4xl mb-3 block"></i>
        <p class="text-sm text-gray-400">No categories yet. Add one!</p>
      </div>
    <% } else { %>
      <div class="divide-y divide-gray-50">
        <% categories.forEach(cat => { %>
          <div class="px-6 py-4 flex items-center gap-4 hover:bg-gray-50/50 transition-colors" id="cat-<%= cat._id %>">
            <!-- Image -->
            <div class="w-14 h-14 rounded-xl overflow-hidden bg-gray-100 flex-shrink-0">
              <% if (cat.image) { %>
                <img src="<%= cat.image %>" alt="<%= cat.name %>" class="w-full h-full object-cover" />
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-gray-300"><i class="fas fa-image"></i></div>
              <% } %>
            </div>

            <!-- Info -->
            <div class="flex-grow min-w-0">
              <p class="font-semibold text-gray-800"><%= cat.name %></p>
              <p class="text-xs text-gray-400 mt-0.5">/<%= cat.slug %> • Order: <%= cat.sortOrder %></p>
              <% if (cat.description) { %>
                <p class="text-xs text-gray-500 mt-0.5 truncate"><%= cat.description %></p>
              <% } %>
            </div>

            <!-- Status -->
            <span class="<%= cat.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %> text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0">
              <%= cat.active ? 'Active' : 'Inactive' %>
            </span>

            <!-- Actions -->
            <div class="flex gap-2 flex-shrink-0">
              <button
                type="button"
                class="w-8 h-8 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center transition-colors"
                title="Edit"
                onclick="editCategory(${JSON.stringify(cat)})"
                <i class="fas fa-edit text-xs"></i>
              </button>

              <button
                type="button"
                class="w-8 h-8 bg-red-50 hover:bg-red-100 text-red-500 rounded-lg flex items-center justify-center transition-colors"
                title="Delete"
                onclick="deleteCategory('<%= cat._id %>','<%- (cat.name || '').replace(/'/g, "\\'") %>')">
                <i class="fas fa-trash text-xs"></i>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" onclick="closeModal(event)">
  <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-md" onclick="event.stopPropagation()">
    <h3 class="font-playfair text-lg font-bold text-gray-800 mb-5">Edit Category</h3>
    <form id="editForm" method="POST" enctype="multipart/form-data" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Category Name</label>
        <input type="text" name="name" id="editName" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
        <textarea name="description" id="editDescription" rows="2" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all resize-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">New Image (optional)</label>
        <input type="file" name="image" accept="image/*" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Sort Order</label>
          <input type="number" name="sortOrder" id="editSortOrder" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
          <select name="active" id="editActive" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all text-gray-600">
            <option value="true">Active</option>
            <option value="false">Inactive</option>
          </select>
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 bg-maroon hover:bg-maroon-light text-white py-3 rounded-xl text-sm font-semibold transition-all">Save Changes</button>
        <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="flex-1 border border-gray-200 text-gray-500 hover:border-maroon hover:text-maroon py-3 rounded-xl text-sm font-medium transition-all">Cancel</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/admin-footer') %>

<script>
  function editCategory(cat) {
    document.getElementById('editForm').action = `/admin/categories/edit/${cat._id}`;
    document.getElementById('editName').value = cat.name || '';
    document.getElementById('editDescription').value = cat.description || '';
    document.getElementById('editSortOrder').value = cat.sortOrder ?? 0;
    document.getElementById('editActive').value = (cat.active ?? true).toString();
    document.getElementById('editModal').classList.remove('hidden');
  }

  function closeModal(e) {
    if (e.target === document.getElementById('editModal')) {
      document.getElementById('editModal').classList.add('hidden');
    }
  }

  function deleteCategory(id, name) {
    if (!confirm(`Delete category "${name}"? This will fail if products exist in this category.`)) return;

    fetch(`/admin/categories/${id}`, { method: 'DELETE' })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showAdminToast(data.message, 'success');
          setTimeout(() => location.reload(), 1000);
        } else {
          showAdminToast(data.message, 'error');
        }
      });
  }
</script>

