<%- include('../partials/admin-header') %>

<!-- Stats Cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-12 h-12 bg-maroon-pale rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-box text-maroon text-lg"></i>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800 font-playfair"><%= totalProducts %></p>
      <p class="text-xs text-gray-400 uppercase tracking-wider">Products</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-shopping-cart text-blue-500 text-lg"></i>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800 font-playfair"><%= totalOrders %></p>
      <p class="text-xs text-gray-400 uppercase tracking-wider">Total Orders</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-rupee-sign text-green-500 text-lg"></i>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800 font-playfair">₹<%= totalRevenue.toLocaleString('en-IN') %></p>
      <p class="text-xs text-gray-400 uppercase tracking-wider">Revenue</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-12 h-12 bg-gold-pale rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-calendar-day text-gold text-lg"></i>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800 font-playfair"><%= todayOrders %></p>
      <p class="text-xs text-gray-400 uppercase tracking-wider">Today's Orders</p>
    </div>
  </div>
</div>

<!-- Order Status Summary -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
  <a href="/admin/orders?status=Pending" class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-center hover:bg-yellow-100 transition-colors">
    <p class="text-xl font-bold text-yellow-600 font-playfair"><%= statusCounts.pending %></p>
    <p class="text-xs text-yellow-600 font-medium mt-0.5">Pending</p>
  </a>
  <a href="/admin/orders?status=Confirmed" class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-center hover:bg-blue-100 transition-colors">
    <p class="text-xl font-bold text-blue-600 font-playfair"><%= statusCounts.confirmed %></p>
    <p class="text-xs text-blue-600 font-medium mt-0.5">Confirmed</p>
  </a>
  <a href="/admin/orders?status=Shipped" class="bg-purple-50 border border-purple-200 rounded-xl p-4 text-center hover:bg-purple-100 transition-colors">
    <p class="text-xl font-bold text-purple-600 font-playfair"><%= statusCounts.shipped %></p>
    <p class="text-xs text-purple-600 font-medium mt-0.5">Shipped</p>
  </a>
  <a href="/admin/orders?status=Delivered" class="bg-green-50 border border-green-200 rounded-xl p-4 text-center hover:bg-green-100 transition-colors">
    <p class="text-xl font-bold text-green-600 font-playfair"><%= statusCounts.delivered %></p>
    <p class="text-xs text-green-600 font-medium mt-0.5">Delivered</p>
  </a>
  <a href="/admin/orders?status=Cancelled" class="bg-red-50 border border-red-200 rounded-xl p-4 text-center hover:bg-red-100 transition-colors">
    <p class="text-xl font-bold text-red-600 font-playfair"><%= statusCounts.cancelled %></p>
    <p class="text-xs text-red-600 font-medium mt-0.5">Cancelled</p>
  </a>
</div>

<!-- Quick Actions + Recent Orders -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Quick Actions -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="font-playfair text-lg font-bold text-gray-800 mb-4">Quick Actions</h2>
    <div class="space-y-3">
      <a href="/admin/products/add" class="flex items-center gap-3 p-3 bg-maroon-pale hover:bg-maroon hover:text-white rounded-xl transition-all group text-maroon">
        <i class="fas fa-plus-circle w-5 text-center"></i>
        <span class="text-sm font-medium">Add New Product</span>
      </a>
      <a href="/admin/categories" class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-500 hover:text-white rounded-xl transition-all group text-blue-600">
        <i class="fas fa-tags w-5 text-center"></i>
        <span class="text-sm font-medium">Manage Categories</span>
      </a>
      <a href="/admin/orders?status=Pending" class="flex items-center gap-3 p-3 bg-yellow-50 hover:bg-yellow-500 hover:text-white rounded-xl transition-all group text-yellow-600">
        <i class="fas fa-clock w-5 text-center"></i>
        <span class="text-sm font-medium">Pending Orders (<%= statusCounts.pending %>)</span>
      </a>
      <a href="/admin/banners" class="flex items-center gap-3 p-3 bg-purple-50 hover:bg-purple-500 hover:text-white rounded-xl transition-all group text-purple-600">
        <i class="fas fa-images w-5 text-center"></i>
        <span class="text-sm font-medium">Manage Banners</span>
      </a>
      <a href="/admin/settings" class="flex items-center gap-3 p-3 bg-gray-50 hover:bg-gray-600 hover:text-white rounded-xl transition-all group text-gray-600">
        <i class="fas fa-cog w-5 text-center"></i>
        <span class="text-sm font-medium">Business Settings</span>
      </a>
    </div>
  </div>

  <!-- Recent Orders -->
  <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-playfair text-lg font-bold text-gray-800">Recent Orders</h2>
      <a href="/admin/orders" class="text-maroon text-sm hover:underline font-medium">View All →</a>
    </div>
    <% if (recentOrders.length === 0) { %>
      <div class="text-center py-8 text-gray-300">
        <i class="fas fa-shopping-cart text-4xl mb-3 block"></i>
        <p class="text-sm">No orders yet</p>
      </div>
    <% } else { %>
      <div class="space-y-3">
        <% recentOrders.forEach(order => { %>
          <a href="/admin/orders/<%= order._id %>" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors group">
            <div class="w-9 h-9 bg-maroon-pale rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-shopping-bag text-maroon text-xs"></i>
            </div>
            <div class="flex-grow min-w-0">
              <p class="text-sm font-semibold text-gray-700 group-hover:text-maroon transition-colors">#<%= order.orderNumber %></p>
              <p class="text-xs text-gray-400 truncate"><%= order.customer.name %> • <%= order.customer.phone %></p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="text-sm font-bold text-gray-700">₹<%= order.totalAmount.toFixed(0) %></p>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= order.status === 'Pending' ? 'bg-yellow-100 text-yellow-700' :
                   order.status === 'Confirmed' ? 'bg-blue-100 text-blue-700' :
                   order.status === 'Shipped' ? 'bg-purple-100 text-purple-700' :
                   order.status === 'Delivered' ? 'bg-green-100 text-green-700' :
                   'bg-red-100 text-red-700' %>">
                <%= order.status %>
              </span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/admin-footer') %>
