<%- include('partials/header') %>
<section class="flex items-center justify-center min-h-[70vh] bg-cream px-4">
  <div class="text-center max-w-md">
    <p class="font-playfair text-8xl font-bold text-maroon/20 mb-4">500</p>
    <h1 class="font-playfair text-3xl font-bold text-gray-700 mb-3">Server Error</h1>
    <p class="text-gray-400 mb-4">Something went wrong on our end. Please try again later.</p>
    <% if (error && process.env?.NODE_ENV === 'development') { %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-left">
        <code class="text-xs text-red-600 break-all"><%= error %></code>
      </div>
    <% } %>
    <a href="/" class="inline-flex items-center gap-2 bg-maroon hover:bg-maroon-light text-white px-8 py-4 rounded-full font-raleway font-semibold transition-all hover:shadow-lg">
      <i class="fas fa-home"></i> Go Home
    </a>
  </div>
</section>
<%- include('partials/footer') %>
