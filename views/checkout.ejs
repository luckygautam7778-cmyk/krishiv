<%- include('partials/header') %>

<!-- Page Header -->
<div class="bg-maroon text-white py-10 px-4">
  <div class="max-w-7xl mx-auto">
    <h1 class="font-playfair text-3xl md:text-4xl font-bold">Checkout</h1>
    <div class="flex items-center gap-2 text-white/60 text-sm mt-2">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <i class="fas fa-chevron-right text-xs"></i>
      <a href="/cart" class="hover:text-gold transition-colors">Cart</a>
      <i class="fas fa-chevron-right text-xs"></i>
      <span class="text-gold">Checkout</span>
    </div>
  </div>
</div>

<section class="py-10 md:py-14 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <% const checkoutDraftSafe = (typeof checkoutDraft === 'undefined') ? null : checkoutDraft; %>
    <% const step = checkoutDraftSafe?.step || 'delivery'; %>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- ── LEFT: FLOW ── -->
      <div class="lg:w-2/3 space-y-6">

        <!-- Delivery + Payment (step=delivery) -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" id="step-delivery" style="display: <%= (step === 'delivery') ? 'block' : 'none' %>;">
          <h2 class="font-playfair text-xl font-bold text-gray-800 mb-5 flex items-center gap-2">
            <i class="fas fa-map-marker-alt text-maroon text-base"></i>
            Delivery & Payment
          </h2>

          <form id="initForm" action="/checkout/init" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Name <span class="text-red-500">*</span></label>
                <input type="text" name="name" required placeholder="Enter your full name"
                  value="<%= checkoutDraft?.delivery?.name || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Mobile Number <span class="text-red-500">*</span></label>
                <input type="tel" name="phone" required placeholder="10-digit mobile number" maxlength="10"
                  pattern="[6-9][0-9]{9}"
                  value="<%= checkoutDraft?.delivery?.phone || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Email (Optional)</label>
                <input type="email" name="email" placeholder="your@email.com"
                  value="<%= checkoutDraft?.delivery?.email || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Address <span class="text-red-500">*</span></label>
                <textarea name="address" required rows="3" placeholder="House No., Street, Area, Landmark..."
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all resize-none"><%= checkoutDraft?.delivery?.address || '' %></textarea>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">City <span class="text-red-500">*</span></label>
                <input type="text" name="city" required placeholder="Your city"
                  value="<%= checkoutDraft?.delivery?.city || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">State <span class="text-red-500">*</span></label>
                <input type="text" name="state" required placeholder="Your state"
                  value="<%= checkoutDraft?.delivery?.state || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Pincode <span class="text-red-500">*</span></label>
                <input type="text" name="pincode" required placeholder="6-digit pincode" maxlength="6" pattern="[0-9]{6}"
                  value="<%= checkoutDraft?.delivery?.pincode || '' %>"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all" />
              </div>

              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Order Notes (Optional)</label>
                <textarea name="notes" rows="2" placeholder="Any special instructions for your order..."
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon focus:ring-1 focus:ring-maroon transition-all resize-none"><%= checkoutDraft?.delivery?.notes || '' %></textarea>
              </div>
            </div>

            <div class="mt-6 bg-gray-50 border border-gray-100 rounded-xl p-4">
              <p class="text-sm font-bold text-gray-800 mb-3">Payment Method</p>

              <div class="space-y-3">
                <label class="flex items-start gap-4 bg-gold-pale border-2 border-gold rounded-xl p-4 cursor-pointer">
                  <input type="radio" name="paymentMethod" value="Online Payment" class="mt-1" <%= (checkoutDraft?.paymentMethod !== 'Cash On Delivery') ? 'checked' : '' %> />
                  <div class="flex-grow">
                    <p class="font-semibold text-gray-800">Online UPI / GPay / PhonePe</p>
                    <p class="text-gray-600 text-sm mt-1">UPI details will be shown in the next step.</p>
                  </div>
                  <i class="fas fa-mobile-screen-button text-gold text-3xl ml-auto"></i>
                </label>

                <% if (settings?.enableCOD) { %>
                  <label class="flex items-start gap-4 border-2 border-gray-200 rounded-xl p-4 cursor-pointer">
                    <input type="radio" name="paymentMethod" value="Cash On Delivery" class="mt-1" <%= (checkoutDraft?.paymentMethod === 'Cash On Delivery') ? 'checked' : '' %> />

                    <div class="flex-grow">
                      <p class="text-gray-600 text-sm mt-1">Pay at delivery.</p>
                      <p class="text-xs text-gray-500 mt-1">COD fee: ₹50</p>
                    </div>

                    <i class="fas fa-truck text-gold text-3xl ml-auto"></i>
                  </label>
                <% } %>
              </div>
            </div>

    <button type="submit" id="buyNowBtn" name="buyNow" class="mt-5 w-full bg-maroon hover:bg-maroon-light text-white font-raleway font-bold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-lg text-base">

              <i class="fas fa-bolt"></i> Buy Now (Start Checkout)
            </button>

            <input type="hidden" name="csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />

          </form>
        </div>

        <!-- UPI payment (QR + upload proof) -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" id="step-upload" style="display:<%= (step === 'upload') ? 'block' : 'none' %>;">
          <h2 class="font-playfair text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
            <i class="fas fa-qrcode text-maroon text-base"></i> Pay via UPI
          </h2>

          <!-- QR + UPI details -->

          <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 mb-4">
            <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
              <div class="w-40 h-40 rounded-lg bg-white border border-gray-200 flex items-center justify-center">
                <% if (activeUpiQrUrl && String(activeUpiQrUrl).trim()) { %>
                  <img src="<%= activeUpiQrUrl %>" alt="Active UPI QR" class="w-full h-full object-contain" />
                <% } else { %>
                  <!-- Never show placeholder QR. If missing, hide the QR entirely. -->
                  <div class="hidden"></div>
                <% } %>
              </div>


              <div class="flex-grow">
                <div class="bg-green-50 border border-green-100 rounded-xl p-3 mb-4">
                  <p class="text-sm text-gray-700 font-semibold">Scan this QR code and complete the payment.</p>
                </div>

                <div class="hidden">
                  <p class="text-sm text-gray-600">UPI ID</p>
                  <p class="font-semibold text-maroon break-all"><%= settings?.upiId || '' %></p>
                  <p class="text-sm text-gray-600 mt-2">Amount Payable</p>
                </div>
                <p class="font-bold text-gray-800 text-lg">₹<%= Number(checkoutDraft?.totals?.totalAmount ?? total).toFixed(0) %></p>
                <p class="text-xs text-gray-500 mt-2">Scan QR, complete payment, then upload your proof screenshot.</p>
              </div>
            </div>
          </div>

          <!-- Upload proof -->
          <h3 class="font-playfair text-lg font-bold text-gray-800 mb-2 flex items-center gap-2">
            <i class="fas fa-camera text-maroon text-base"></i> Upload Payment Screenshot
          </h3>
          <p class="text-gray-600 text-sm mb-3">Upload your UPI payment receipt screenshot for verification.</p>

          <form action="/checkout/upload-payment" method="POST" enctype="multipart/form-data" class="space-y-4">
            <input type="hidden" name="csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Screenshot (Image)</label>
              <input type="file" name="paymentScreenshot" accept="image/*" required
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-maroon transition-all" />
            </div>

            <button type="submit" class="w-full bg-maroon hover:bg-maroon-light text-white font-raleway font-bold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-lg text-base">
              <i class="fas fa-upload"></i> Upload Proof & Continue
            </button>
          </form>
        </div>


        <!-- Confirm step -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6" id="step-confirm" style="display:<%= step === 'confirm' ? 'block' : 'none' %>;">
          <h2 class="font-playfair text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
            <i class="fas fa-check-circle text-maroon text-base"></i> Confirm Order
          </h2>

          <% const totalToShow = checkoutDraft?.totals?.totalAmount ?? total; %>
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 text-sm text-gray-700 mb-4">
            <div class="flex justify-between mb-2"><span>Payment</span><span class="font-semibold"><%= checkoutDraft?.paymentMethod %></span></div>
            <div class="flex justify-between"><span>Total</span><span class="font-semibold text-maroon">₹<%= Number(totalToShow).toFixed(0) %></span></div>
          </div>

          <form action="/checkout/confirm" method="POST">
            <input type="hidden" name="csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
            <button type="submit" class="w-full bg-maroon hover:bg-maroon-light text-white font-raleway font-bold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-lg text-base">
              <i class="fas fa-bell"></i> Confirm & Place Order
            </button>
          </form>



        </div>

      </div>

      <!-- ── RIGHT: SUMMARY ── -->
      <div class="lg:w-1/3">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
          <h2 class="font-playfair text-xl font-bold text-gray-800 mb-5 pb-4 border-b border-gray-100">Your Order</h2>

          <div class="space-y-3 mb-4 max-h-64 overflow-y-auto pr-1">
            <% cart.forEach(item => { %>
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 flex-shrink-0 rounded-lg overflow-hidden bg-gray-50">
                  <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
                  <% } else { %>
                    <div class="w-full h-full bg-gray-100 flex items-center justify-center"><i class="fas fa-image text-gray-300 text-xs"></i></div>
                  <% } %>
                </div>
                <div class="flex-grow min-w-0">
                  <p class="text-sm font-medium text-gray-700 line-clamp-1"><%= item.name %></p>
                  <p class="text-xs text-gray-400">Qty: <%= item.quantity %> × ₹<%= item.price.toFixed(0) %></p>
                </div>
                <p class="text-sm font-semibold text-gray-700 flex-shrink-0">₹<%= (item.price * item.quantity).toFixed(0) %></p>
              </div>
            <% }) %>
          </div>

          <div class="border-t border-gray-100 pt-4 space-y-2 text-sm">
            <div class="flex justify-between text-gray-600">
              <span>Subtotal</span>
              <span class="font-medium">₹<%= subtotal.toFixed(0) %></span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Shipping</span>
              <% if (shipping === 0) { %>
                <span class="text-green-600 font-medium">FREE</span>
              <% } else { %>
                <span class="font-medium">₹<%= shipping.toFixed(0) %></span>
              <% } %>
            </div>
            <% if (settings?.enableCOD && checkoutDraft?.paymentMethod === 'Cash On Delivery') { %>
              <div class="flex justify-between text-gray-600">
                <span>COD Charge</span>
<span class="font-medium text-gray-800">₹<%= (settings?.codFeeAmount ?? 40).toFixed(0) %></span>
              </div>
            <% } %>

            <div class="flex justify-between font-bold text-lg pt-2 border-t border-gray-100">
              <span class="text-gray-800">Total</span>
              <span class="text-maroon font-playfair">₹<%= Number(checkoutDraft?.totals?.totalAmount ?? total).toFixed(0) %></span>
            </div>
          </div>

          <div class="mt-4 text-xs text-gray-400 bg-gray-50 rounded-xl p-3">
            <i class="fas fa-shield-alt text-green-500 mr-1"></i>
            By confirming, you agree to our terms. COD orders are created immediately; UPI orders are created immediately after screenshot upload.
          </div>

          <% if (settings?.enableCOD && checkoutDraft?.paymentMethod === 'Cash On Delivery' && step !== 'delivery') { %>
            <div class="mt-3 text-xs text-gray-500">
              COD selected: no screenshot upload required.
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script>
  (function(){
    const buyForm = document.getElementById('initForm');
    if (!buyForm) return;

    const paymentRadios = buyForm.querySelectorAll('input[name="paymentMethod"]');
    const buyBtn = document.getElementById('buyNowBtn');

    function updateButtonText() {
      if (!buyBtn) return;
      const selected = buyForm.querySelector('input[name="paymentMethod"]:checked')?.value;
      if (selected === 'Cash On Delivery') {
        buyBtn.innerHTML = '<i class="fas fa-check-circle"></i> Place Order (Cash on Delivery)';
      } else {
        buyBtn.innerHTML = '<i class="fas fa-arrow-right"></i> Proceed to Payment';
      }
    }

    paymentRadios.forEach(radio => {
      radio.addEventListener('change', updateButtonText);
    });

    // Run initially
    updateButtonText();

    buyForm.addEventListener('submit', function(){
      if (!buyBtn) return;
      buyBtn.disabled = true;
      const selected = buyForm.querySelector('input[name="paymentMethod"]:checked')?.value;
      if (selected === 'Cash On Delivery') {
        buyBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Placing Order...';
      } else {
        buyBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Starting Checkout...';
      }
    });
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const confirmForm = document.querySelector('form[action="/checkout/confirm"]');
    if (!confirmForm) return;

    const btn = confirmForm.querySelector('button[type="submit"]');
    if (!btn) return;

    confirmForm.addEventListener('submit', () => {
      btn.disabled = true;
      btn.dataset.originalText = btn.dataset.originalText || btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
    });

    window.addEventListener('pageshow', () => {
      if (btn && btn.dataset.originalText) {
        btn.disabled = false;
        btn.innerHTML = btn.dataset.originalText;
      }
    });
  });
</script>

