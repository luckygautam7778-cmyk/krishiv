<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Admin | Krishiv' %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            maroon: { DEFAULT: '#7B1536', light: '#9B2048', dark: '#5C0F28', pale: '#F5E6EC' },
            gold:   { DEFAULT: '#C9A84C', light: '#DFC06A', dark: '#A8882E', pale: '#FBF5E6' },
            sidebar: '#1A0A14',
            'sidebar-hover': '#2D1225',
          },
          fontFamily: {
            playfair: ['"Playfair Display"', 'serif'],
            raleway:  ['Raleway', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <script>window.csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';</script>
</head>
<body class="font-raleway bg-gray-100 min-h-screen flex">

  <!-- ═══════════ SIDEBAR ═══════════ -->
  <aside id="sidebar" class="w-64 min-h-screen bg-sidebar flex-shrink-0 flex flex-col fixed left-0 top-0 h-full z-40 transition-transform duration-300 md:translate-x-0 -translate-x-full">
    <!-- Logo -->
    <div class="px-6 py-6 border-b border-white/10">
      <a href="/admin/dashboard" class="flex flex-col leading-none">
        <span class="font-playfair text-2xl font-bold text-gold">Krishiv</span>
        <span class="text-white/40 text-xs tracking-widest uppercase mt-0.5">Admin Panel</span>
      </a>
    </div>

    <!-- Admin Info -->
    <div class="px-6 py-4 border-b border-white/10 flex items-center gap-3">
      <div class="w-9 h-9 bg-maroon rounded-full flex items-center justify-center flex-shrink-0">
        <i class="fas fa-user-shield text-gold text-sm"></i>
      </div>
      <div>
        <p class="text-white text-sm font-medium"><%= adminUsername || 'Admin' %></p>
        <p class="text-white/40 text-xs">Administrator</p>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-grow px-3 py-4 overflow-y-auto">
      <p class="text-white/30 text-xs uppercase tracking-widest px-3 mb-2">Main</p>

      <a href="/admin/dashboard" class="sidebar-link <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt w-5"></i>
        <span>Dashboard</span>
      </a>

      <p class="text-white/30 text-xs uppercase tracking-widest px-3 mb-2 mt-4">Catalog</p>

      <a href="/admin/products" class="sidebar-link <%= currentPath.startsWith('/admin/products') ? 'active' : '' %>">
        <i class="fas fa-box w-5"></i>
        <span>Products</span>
      </a>

      <a href="/admin/categories" class="sidebar-link <%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>">
        <i class="fas fa-tags w-5"></i>
        <span>Categories</span>
      </a>

      <p class="text-white/30 text-xs uppercase tracking-widest px-3 mb-2 mt-4">Sales</p>

      <a href="/admin/orders" class="sidebar-link <%= currentPath.startsWith('/admin/orders') ? 'active' : '' %>">
        <i class="fas fa-shopping-cart w-5"></i>
        <span>Orders</span>
      </a>

      <p class="text-white/30 text-xs uppercase tracking-widest px-3 mb-2 mt-4">Content</p>

      <a href="/admin/banners" class="sidebar-link <%= currentPath.startsWith('/admin/banners') ? 'active' : '' %>">
        <i class="fas fa-images w-5"></i>
        <span>Banners</span>
      </a>

      <a href="/admin/settings" class="sidebar-link <%= currentPath.startsWith('/admin/settings') ? 'active' : '' %>">
        <i class="fas fa-cog w-5"></i>
        <span>Settings</span>
      </a>

      <p class="text-white/30 text-xs uppercase tracking-widest px-3 mb-2 mt-4">Payment</p>

      <a href="/admin/upi-qr" class="sidebar-link <%= currentPath.startsWith('/admin/upi-qr') ? 'active' : '' %>">
        <i class="fas fa-qrcode w-5"></i>
        <span>UPI QR Management</span>
      </a>


      <div class="mt-auto pt-6">
        <a href="/" target="_blank" class="sidebar-link text-white/50 hover:text-white">
          <i class="fas fa-external-link-alt w-5"></i>
          <span>View Store</span>
        </a>
        <a href="/admin/logout" class="sidebar-link text-red-400 hover:text-red-300 hover:bg-red-900/30">
          <i class="fas fa-sign-out-alt w-5"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>
  </aside>

  <!-- Overlay for mobile -->
  <div id="sidebarOverlay" class="hidden fixed inset-0 bg-black/50 z-30 md:hidden" onclick="toggleSidebar()"></div>

  <!-- ═══════════ MAIN AREA ═══════════ -->
  <div class="flex-1 flex flex-col md:ml-64 min-h-screen">

    <!-- Top Bar -->
    <header class="bg-white shadow-sm h-16 flex items-center justify-between px-4 md:px-6 sticky top-0 z-20">
      <div class="flex items-center gap-4">
        <button onclick="toggleSidebar()" class="md:hidden text-gray-500 hover:text-maroon p-2">
          <i class="fas fa-bars text-xl"></i>
        </button>
        <div>
          <h1 class="font-playfair text-lg md:text-xl font-semibold text-gray-800"><%= pageTitle || 'Admin Panel' %></h1>
          <p class="text-gray-400 text-xs hidden md:block">Krishiv Admin Dashboard</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/" target="_blank" class="hidden sm:flex items-center gap-2 text-sm text-gray-500 hover:text-maroon transition-colors">
          <i class="fas fa-store"></i> <span class="hidden md:inline">View Store</span>
        </a>
        <a href="/admin/logout" class="flex items-center gap-2 bg-red-50 text-red-600 hover:bg-red-100 px-3 py-1.5 rounded-lg text-sm transition-colors">
          <i class="fas fa-sign-out-alt"></i>
          <span class="hidden sm:inline">Logout</span>
        </a>
      </div>
    </header>

    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="mx-4 mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl flex items-center gap-3 shadow-sm" id="adminFlashSuccess">
        <i class="fas fa-check-circle text-green-500"></i>
        <span><%= success_msg %></span>
        <button onclick="this.parentElement.remove()" class="ml-auto text-green-500 hover:text-green-700"><i class="fas fa-times"></i></button>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="mx-4 mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-center gap-3 shadow-sm" id="adminFlashError">
        <i class="fas fa-exclamation-circle text-red-500"></i>
        <span><%= error_msg %></span>
        <button onclick="this.parentElement.remove()" class="ml-auto text-red-500 hover:text-red-700"><i class="fas fa-times"></i></button>
      </div>
    <% } %>

    <!-- Page Content -->
    <main class="flex-grow p-4 md:p-6">
