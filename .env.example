# ================================
# POSHAAK - Environment Variables
# ================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/poshaak
# For MongoDB Atlas use:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/poshaak?retryWrites=true&w=majority

# Session Secret (use a long random string in production)
SESSION_SECRET=poshaak-super-secret-session-key-change-this-in-production

# Admin Credentials (used during seeding)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@poshaak.in
ADMIN_PASSWORD=Admin@12345

# Business Info
BUSINESS_NAME=Poshaak
WHATSAPP_NUMBER=919876543210
